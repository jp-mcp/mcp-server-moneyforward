# Money Forward Cloud API Configuration
# Either MF_ACCESS_TOKEN or MF_API_KEY is required

# OAuth2.0 Access Token (for user-based authentication)
MF_ACCESS_TOKEN=

# API Key (for server-to-server authentication)
MF_API_KEY=

# Office/Company ID (required)
MF_OFFICE_ID=

# OAuth2.0 credentials (optional, for token refresh)
MF_CLIENT_ID=
MF_CLIENT_SECRET=
